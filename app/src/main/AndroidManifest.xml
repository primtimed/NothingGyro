<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="com.nothing.ketchum.permission.ENABLE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.DayNight.NoActionBar">

        <!-- Main activity so the app appears in launcher -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- App Widget Provider -->
        <receiver
            android:name=".DogWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BATTERY_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dog_widget_info" />
        </receiver>

        <!-- Glyph Service -->
        <service
            android:name=".GlyphDogService"
            android:exported="true"
            android:permission="com.nothing.ketchum.permission.ENABLE">
            <intent-filter>
                <action android:name="com.nothing.ketchum.GlyphService" />
            </intent-filter>
        </service>

    </application>
</manifest>
